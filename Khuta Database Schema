-- Khuta Database Schema
-- Generated from the exported database structure.
-- This file creates the tables with Primary Keys and Foreign Keys.
-- Note: PostGIS is required for geometry columns.

CREATE EXTENSION IF NOT EXISTS postgis;

-- =========================
-- Independent Tables
-- =========================

CREATE TABLE IF NOT EXISTS users (
    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name character varying NOT NULL,
    email character varying NOT NULL,
    password_hash character varying NOT NULL,
    gender character varying NOT NULL,
    age integer NOT NULL,
    phone character varying,
    is_verified boolean,
    favorite_club character varying,
    role character varying DEFAULT 'user'::character varying
);

CREATE TABLE IF NOT EXISTS matches (
    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    home_team character varying NOT NULL,
    away_team character varying NOT NULL,
    match_time timestamp without time zone NOT NULL,
    stadium character varying,
    status character varying,
    home_score integer,
    away_score integer,
    minute character varying,
    base_price numeric NOT NULL DEFAULT 100
);

CREATE TABLE IF NOT EXISTS sections (
    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    stand text,
    section text,
    row integer,
    height numeric,
    base numeric,
    color text,
    geom geometry
);

CREATE TABLE IF NOT EXISTS facilities (
    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name_ar text,
    type text,
    geom geometry
);

CREATE TABLE IF NOT EXISTS gates (
    id text PRIMARY KEY,
    type text,
    name text,
    name_ar text,
    part text,
    geom geometry
);

CREATE TABLE IF NOT EXISTS routing_networklines (
    id integer PRIMARY KEY,
    name text,
    source integer,
    target integer,
    cost double precision,
    reverse_cost double precision,
    floor_id integer,
    network_type text DEFAULT 'corridor'::text,
    floor_name text DEFAULT 'z1'::text,
    floor_num integer DEFAULT 1,
    length numeric,
    speed numeric,
    access_type text DEFAULT 'walk'::text,
    matched_to_3d_walkways boolean,
    geom geometry
);

CREATE TABLE IF NOT EXISTS routing_networklines_vertices_pgr (
    id bigint GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    cnt integer,
    chk integer,
    ein integer,
    eout integer,
    the_geom geometry
);

-- spatial_ref_sys is usually created automatically by PostGIS.
-- Do not recreate it unless your local database does not have PostGIS installed.

-- =========================
-- Dependent Tables
-- =========================

CREATE TABLE IF NOT EXISTS seats (
    id integer PRIMARY KEY,
    seat_id text NOT NULL,
    stand text,
    section text,
    row integer,
    seat integer,
    status text DEFAULT 'available'::text,
    poi_id integer,
    lon double precision,
    lat double precision,
    geom geometry,
    match_id integer NOT NULL,
    section_id integer,
    CONSTRAINT fk_seats_match
        FOREIGN KEY (match_id)
        REFERENCES matches(id),
    CONSTRAINT fk_seats_section
        FOREIGN KEY (section_id)
        REFERENCES sections(id)
);

CREATE TABLE IF NOT EXISTS payment (
    id bigint PRIMARY KEY,
    booking_id bigint NOT NULL,
    amount numeric NOT NULL,
    payment_method character varying NOT NULL DEFAULT ''::character varying,
    card_last4 character varying,
    status character varying DEFAULT 'pending'::character varying,
    transaction_code character varying,
    paid_at timestamp without time zone NOT NULL DEFAULT now()
);

CREATE TABLE IF NOT EXISTS tickets (
    id integer PRIMARY KEY,
    qr_token character varying NOT NULL,
    payment_id integer,
    match_id integer NOT NULL,
    seat_id integer NOT NULL,
    seat_number character varying NOT NULL,
    user_name character varying NOT NULL,
    price numeric NOT NULL,
    status character varying NOT NULL DEFAULT 'active'::character varying,
    stadium_name character varying NOT NULL DEFAULT ' '::character varying,
    match_date date NOT NULL,
    match_time time without time zone NOT NULL,
    created_at timestamp without time zone NOT NULL DEFAULT now(),
    base_price numeric NOT NULL DEFAULT 0,
    user_id integer,
    CONSTRAINT fk_tickets_match
        FOREIGN KEY (match_id)
        REFERENCES matches(id),
    CONSTRAINT fk_tickets_payment
        FOREIGN KEY (payment_id)
        REFERENCES payment(id),
    CONSTRAINT fk_tickets_seat
        FOREIGN KEY (seat_id)
        REFERENCES seats(id),
    CONSTRAINT fk_tickets_user
        FOREIGN KEY (user_id)
        REFERENCES users(id)
);

CREATE TABLE IF NOT EXISTS reset_tokens (
    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    otp character varying NOT NULL,
    user_id integer NOT NULL,
    expires_at timestamp without time zone NOT NULL,
    CONSTRAINT fk_reset_tokens_user
        FOREIGN KEY (user_id)
        REFERENCES users(id)
);

CREATE TABLE IF NOT EXISTS verification_tokens (
    id integer GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    user_id integer NOT NULL,
    expires_at timestamp without time zone NOT NULL,
    otp character varying,
    CONSTRAINT fk_verification_tokens_user
        FOREIGN KEY (user_id)
        REFERENCES users(id)
);

-- =========================
-- Optional Indexes
-- =========================

CREATE INDEX IF NOT EXISTS idx_users_email ON users(email);
CREATE INDEX IF NOT EXISTS idx_seats_match_id ON seats(match_id);
CREATE INDEX IF NOT EXISTS idx_seats_section_id ON seats(section_id);
CREATE INDEX IF NOT EXISTS idx_tickets_match_id ON tickets(match_id);
CREATE INDEX IF NOT EXISTS idx_tickets_seat_id ON tickets(seat_id);
CREATE INDEX IF NOT EXISTS idx_tickets_user_id ON tickets(user_id);
CREATE INDEX IF NOT EXISTS idx_reset_tokens_user_id ON reset_tokens(user_id);
CREATE INDEX IF NOT EXISTS idx_verification_tokens_user_id ON verification_tokens(user_id);

